{%- assign slider_type = block.settings.slider_showhide -%}
{%- assign select_collections = block.settings.select_collections -%}
{%- assign select_products = block.settings.select_products -%}

{% comment %} Override font family, font color and font size {% endcomment %}
{% if block.settings['override-font_family'] == true %}
  <style>
     {% assign header_font = block.settings.font_family %}
       {{ header_font | font_face }}
     #shopify-section-{{ section.id }} .owl-item h3 { font-family:{{ header_font.family }}; }
     #shopify-section-{{ section.id }} .product_price { font-family:{{ header_font.family }}; }
    #shopify-section-{{ section.id }}  button.add-to-cart-button { font-family:{{ header_font.family }}; }
  </style>
{% endif %}
{% if block.settings['override-fontColor_slider'] == true %}
  <style>
    #shopify-section-{{ section.id }} .owl-item h3 {color: {{ block.settings.font_color }};}
    #shopify-section-{{ section.id }} button.add-to-cart-button {background-image: {{ block.settings.button_bg_color }};color: {{ block.settings.button_color }};border: none;}
    #shopify-section-{{ section.id }} .product-on-sale-badge {background: {{ block.settings.badge_bg_color }};color: {{ block.settings.badge_color }};}
    #shopify-section-{{ section.id }} button.add-to-cart-button:hover {background-color: {{ block.settings.button_bg_color }};color: {{ block.settings.button_color }};}
  </style>
{% endif %}
{% if block.settings['override-fontSize_slider'] == true %}
  <style>
    #shopify-section-{{ section.id }} .product-on-sale-badge {font-size: {{ block.settings.badge_font_size | append: 'px' }};}
    #shopify-section-{{ section.id }} .owl-item h3 {font-size: {{ block.settings.font_size | append: 'px' }};}
  </style>
{% endif %}
{% comment %} Get slider item count {% endcomment %}
{% assign cols_string = block.settings.columns_config | remove: '{' | remove: '}' | replace: '"', '' | strip %}
{% assign parts = cols_string | split: ',' %}
{% assign desktop = parts[0] | split: ':' | last | strip %}
{% assign tablet = parts[1] | split: ':' | last | strip %}
{% assign mobile = parts[2] | split: ':' | last | strip %}

{% assign beatles = block.settings.ads_parameter | split: ',' %}
{% assign ads_param = beatles | join: ' ' %}
<div class="product-pagesidebar1 product-slider-widget">
  {%- # Label: Select Collections # -%}
  
  <h2>{{ block.settings['main-heading'] }}</h2>
  <div class="pro_desc">
    <p>{{ block.settings.description }}</p>
  </div>
  {% if slider_type == 'show_collection_slider' %}
    {% assign page_product = product %}
    {% assign shown_products = '' %}
    <div class="owl-carousel {{ section.id }}">
      {%- for collection in select_collections -%}
        {%- for product in collection.products -%}
          {% unless shown_products contains product.id or product.id == page_product.id %}
            {% assign shown_products = shown_products | append: product.id | append: ',' %}
            <a href="{{ product.url }}?{{ block.settings.ads_parameter }}">
              <div class="item">
                <div class="product-item">
                  <div class="slider-image ratio ratio-1x1">
                    {{ product.featured_image | image_url: width: 600, height: 600 | image_tag }}
                  </div>
                  <h3>{{ product.title }}</h3>
                  {% if product.compare_at_price_max > product.price %}
                    <div class="product-on-sale-badge card__badge badge">
                      {{ block.settings.sale_badge }}
                    </div>
                  {% endif %}
                  {% if block.settings.hide_stock_bedge == false %}
                    {% if product.available %}
                      <div class="available_status card__badge badge">In Stock</div>
                    {% else %}
                      <div class="available_status card__badge badge">Sold out</div>
                    {% endif %}
                  {% endif %}
                  <div class="product_price">
                    <span class="regular-price">
                      {{ product.compare_at_price | money_with_currency }}
                    </span>
                    <span class="sale-price">
                      {{ product.price | money_with_currency }}
                    </span>
                  </div>
                  {% if block.settings.hide_add_to_cart_button == false %}
                    <form action="{{ routes.cart_add_url }}" method="post" class="add-to-cart-form">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="add-to-cart-button" alt="Add to Cart" title="Add to Cart">
                        Add to Cart
                      </button>
                    </form>
                  {% endif %}
                </div>
              </div>
            </a>
          {% endunless %}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  {% endif %}
  {%- # Label: Select Products # -%}
  
  {% if slider_type == 'show_product_slider' %}
    <div class="owl-carousel {{ section.id }}">
      {%- for product in select_products -%}
        <a href="{{ product.handle }}?{{ block.settings.ads_parameter }}">
          <div class="item">
            <div class="product-item">
              <div class="slider-image ratio ratio-1x1">
                {{ product.featured_image | image_url: width: 300, height: 300 | image_tag }}
              </div>
              <h3>{{ product.title | truncate: 35 }}</h3>
              {% if product.compare_at_price_max > product.price %}
                <div class="product-on-sale-badge card__badge badge">
                  {{ block.settings.sale_badge }}
                </div>
              {% endif %}
              {% if block.settings.hide_stock_bedge == false %}
                {% if product.available %}
                  <div class="available_status card__badge badge">In Stock</div>
                {% else %}
                  <div class="available_status card__badge badge">Sold out</div>
                {% endif %}
              {% endif %}
              <div class="product_price">
                <span class="regular-price">
                  {{ product.compare_at_price | money_with_currency }}
                </span>
                <span class="sale-price">
                  {{ product.price | money_with_currency }}
                </span>
              </div>
              {% if block.settings.hide_add_to_cart_button == false %}
                {% if product.variants.size > 1 %}
                  <button type="submit" class="add-to-cart-button selec">Select Option</button>
                {% else %}
                  <form action="{{ routes.cart_add_url }}" method="post">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="add-to-cart-button add" alt="Add to Cart" title="Add to Cart">
                      Add to Cart
                    </button>
                  </form>
                {% endif %}
              {% endif %}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {% endif %}
</div>
<script>
    jQuery(document).ready(function($) {
     $('.owl-carousel.{{ section.id }}').owlCarousel({
    loop: {{ block.settings.slider_loop }},
    lazyLoad: false,
    animateOut: 'fadeOut',
    margin: {{ block.settings.slider_margin }},
    center: {{ block.settings.slider_center }},
    nav: {{ block.settings.slider_arrow }},
    autoplay: {{ block.settings.slider_autoplay }},
    responsive: {
      0: {
        items: {{ mobile }}
      },
      600: {
        items: {{ tablet }}
      },
      1000: {
        items: {{ desktop}}
      }
    }
  })
    });
</script>

<script type="text/javascript">
  $(document).ready(function () {
    // Sample query string
    const queryString = $(location).attr('href').split('?');
    // The parameter you want to search for
    const searchParam = '{{ ads_param }}';
    // Split the query string into individual parameters
    const parameters = queryString[1].split('&');
    // console.log(parameters);
    // Initialize a variable to store the value of the parameter if found
    let foundValue = null;

    // Iterate through the parameters
    for (const param of parameters) {
      const [key, value] = param.split('=');
      //console.log(key);
      if (key === searchParam) {
        foundValue = key;
        break; // Exit the loop if the parameter is found
      }
    }
    // Check if the parameter was found and log its value
    if (foundValue !== null) {
      $('.product-pagesidebar1').addClass('showsidebar');
      console.log(`The value of '${searchParam}' is '${foundValue}'`);
    } else {
      console.log(`'${searchParam}' not found in the query string`);
    }
  });
</script>
{% schema %}
{
  "name": "Product Slider Widget",
  "target": "section",
  "stylesheet": "stylesheet.css",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    { "type": "header", "content": "Product Slider Widget Settings" },
    { "type": "text", "id": "main-heading", "label": "Section Heading", "default": "Featured Products" },
    {
      "type": "checkbox",
      "id": "override-fontSize_slider",
      "label": "Override default theme font size with App settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "override-fontColor_slider",
      "label": "Override default theme font color with App settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "override-font_family",
      "label": "Override default theme font family with App settings",
      "default": false
    },
    { "type": "richtext", "id": "description", "label": "Description" },
    {
      "type": "select",
      "id": "slider_showhide",
      "label": "Slider Display Type",
      "options": [
        { "value": "show_collection_slider", "label": "Collection slider" },
        { "value": "show_product_slider", "label": "Product slider" }
      ],
      "default": "show_collection_slider",
      "info": "Select which slider you want to display in this section."
    },
    { "type": "header", "content": "Collection Slider" },
    {
      "type": "collection_list",
      "id": "select_collections",
      "label": "Select Collections",
      "limit": 20,
      "info": "Please select collections"
    },
    { "type": "header", "content": "Product Slider" },
    {
      "type": "product_list",
      "id": "select_products",
      "label": "Select Products",
      "limit": 20,
      "info": "Please select products"
    },
    { "type": "header", "content": "Slider Settings" },
    {
      "type": "textarea",
      "id": "columns_config",
      "label": "Columns (Desktop, Tablet, Mobile)",
      "default": "{ \"desktop\": 4, \"tablet\": 3, \"mobile\": 2 }",
      "info": "Enter JSON like: { \"desktop\": 4, \"tablet\": 3, \"mobile\": 2 }"
    },
    {
      "type": "radio",
      "id": "slider_arrow",
      "label": "Slider Arrow",
      "options": [
        { "value": "true", "label": "Yes" },
        { "value": "false", "label": "No" }
      ],
      "default": "false"
    },
    {
      "type": "radio",
      "id": "slider_autoplay",
      "label": "Slider Autoplay",
      "options": [
        { "value": "true", "label": "Yes" },
        { "value": "false", "label": "No" }
      ],
      "default": "false"
    },
    {
      "type": "radio",
      "id": "slider_center",
      "label": "Slider Center mode",
      "options": [
        { "value": "true", "label": "Yes" },
        { "value": "false", "label": "No" }
      ],
      "default": "false"
    },
    {
      "type": "radio",
      "id": "slider_loop",
      "label": "Slider loop",
      "options": [
        { "value": "true", "label": "Yes" },
        { "value": "false", "label": "No" }
      ],
      "default": "true"
    },
    {
      "type": "range",
      "id": "slider_margin",
      "label": "Item Margin",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "hide_add_to_cart_button",
      "label": "Hide add to cart button",
      "default": true,
      "info": "Toggle to show or hide the Add to Cart button in the slider"
    },
    {
      "type": "checkbox",
      "id": "hide_stock_bedge",
      "label": "Hide stock bedge",
      "default": true,
      "info": "Toggle to show or hide the stock badge on products."
    },
    { "type": "header", "content": "Slider Appearance" },
    { "type": "color_background", "id": "button_bg_color", "label": "Button Background Color" },
    { "type": "color", "id": "button_color", "label": "Button text color" },
    { "type": "font_picker", "id": "font_family", "label": "Font family", "default": "helvetica_n4" },
    {
      "type": "range",
      "id": "font_size",
      "label": "Title Font size",
      "min": 5,
      "max": 30,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    { "type": "color", "id": "font_color", "label": "Title Font Color", "default": "#444" },
    { "type": "text", "id": "sale_badge", "label": "Sale Badge Text", "default": "Sale" },
    {
      "type": "color_background",
      "id": "badge_bg_color",
      "label": "Badge bg color",
      "default": "linear-gradient(#ffffff, #000000)"
    },
    { "type": "color", "id": "badge_color", "label": "Badge color", "default": "#ffffff" },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Badge Font size",
      "min": 5,
      "max": 30,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    { "type": "header", "content": "Ads parameter Setting" },
    {
      "type": "text",
      "id": "ads_parameter",
      "label": "Ads parameter",
      "placeholder": "Enter Ads parameter",
      "info": "Please enter ads parameter in above box for show/hide slider with url"
    }
  ]
}
{% endschema %}
